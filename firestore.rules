rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Portal Kurikulum Digital SJKT Kuala Lipis
    match /schools/sjkt-kuala-lipis/portal/{docId} {
      // Guru boleh lihat portal tanpa login
      allow read: if true;

      // Hanya admin/GPK yang login dengan email ini boleh edit
      // Tukar email di bawah kepada email admin sebenar.
      allow write: if request.auth != null
                   && request.auth.token.email in [
                     "email-admin-sekolah@gmail.com"
                   ];
    }
  }
}
